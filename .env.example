# Server
PORT=3000
NODE_ENV=development

# Database (SQLite para desenvolvimento)
DB_STORAGE=./dev.sqlite
DB_TEST_STORAGE=:memory:

# Database (PostgreSQL para produção — configure no Coolify)
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=

# Cigam API
CIGAM_API_BASE_URL=https://api.cigam.com.br
CIGAM_API_TOKEN=seu-token-aqui

# Security
CORS_ORIGIN=*
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Frontend (build arg)
VITE_API_URL=/api/v1
